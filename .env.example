# ──────────────────────────────────────────────────────────────
# Stablerails — environment template
# Copy to .env and fill in values. Never commit .env.
# ──────────────────────────────────────────────────────────────

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/stablerails"

# ── Tron RPC endpoints — SERVER / WORKER (dual provider) ──
# Read by src/workers/index.ts and src/lib/http.ts
# Primary: TronGrid
TRON_RPC_PRIMARY_URL="https://api.trongrid.io"
TRON_RPC_PRIMARY_API_KEY="your-trongrid-api-key-here"

# Secondary: NowNodes / any independent Tron-compatible node (MUST differ from primary)
TRON_RPC_SECONDARY_URL="https://tronnodes.com"
TRON_RPC_SECONDARY_API_KEY="your-secondary-api-key-here"

# ── Tron RPC — CLI sweep broadcast toggle ──
# Read ONLY by src/cli/commands/sweep.ts to enable live broadcast.
# When unset: sweep execute signs locally but does NOT broadcast (implicit dry-run).
# When set:   sweep execute signs + broadcasts to the Tron network.
# Not required for the server or worker — those use TRON_RPC_PRIMARY_URL above.
TRON_RPC_PRIMARY=""
TRON_RPC_SECONDARY=""

# ── Canonical USDT contract (Tron mainnet – TRC-20) ──
# TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t — pinned, never override
TRON_USDT_CONTRACT="TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t"

# ── Block scanning ──
# Watcher poll interval in milliseconds (default: 5000). Read by src/workers/index.ts.
WATCHER_POLL_INTERVAL_MS="5000"

# ── Server ──
HOST="0.0.0.0"
PORT="3000"
LOG_LEVEL="info"

# ── Public URL ──
# Base URL for hosted checkout links (e.g. https://pay.example.com).
# Read by src/server/index.ts and src/server/routes/invoices.ts.
PUBLIC_BASE_URL="http://localhost:3000"

# ── Kill-switches ──
# Set to "1" to pause the corresponding subsystem at startup.
# Also togglable at runtime via pauseArea()/resumeArea() in src/server/killswitch.ts.
STABLERAILS_PAUSE_INVOICES=""    # POST /v1/invoices returns 503 when "1"
STABLERAILS_PAUSE_WATCHER=""     # Block watcher skips each poll tick when "1"
STABLERAILS_PAUSE_WEBHOOKS=""    # Webhook delivery drain skips all rows when "1"

# ── CLI / Signer (local operator machine only) ──
# Admin bearer key — required for all CLI API requests (src/cli/apiClient.ts).
STABLERAILS_ADMIN_KEY="your-admin-key-here"

# Server base URL for the CLI (default: http://localhost:3000). Read by src/cli/apiClient.ts.
STABLERAILS_API_URL="http://localhost:3000"

# Encrypted seed blob — required for seed operations (event create, sweep execute).
# Use either STABLERAILS_ENCRYPTED_SEED (inline JSON) or STABLERAILS_SEED_FILE (path to file).
# Read by src/cli/seedStore.ts.
STABLERAILS_ENCRYPTED_SEED='{"ciphertext":"...","salt":"...","iv":"...","tag":"..."}'
# STABLERAILS_SEED_FILE="/path/to/seed.json"

# ── Metrics ───────────────────────────────────────────────────────────────────
# Prometheus scrape endpoint GET /metrics.
# Empty (default) = endpoint disabled → responds 404 (feature hidden).
# Set to a long random secret to enable: bearer token required for every scrape.
# Never expose /metrics publicly; put it behind network ACLs or a reverse-proxy
# allow-list restricted to your Prometheus scraper IP.
METRICS_TOKEN=
