{
  "name": "stablerails",
  "version": "0.1.0",
  "description": "Stablerails — free, open-source, self-hosted, non-custodial stablecoin payment software (watch-only server, local signer)",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stablerails/stablerails.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/workers/index.ts",
    "cli:mcp": "tsx src/mcp/bin.ts",
    "build": "prisma generate && tsc",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit:ci": "audit-ci --config audit-ci.jsonc"
  },
  "bin": {
    "stablerails": "dist/cli/index.js",
    "stablerails-mcp": "dist/mcp/bin.js"
  },
  "files": [
    "dist",
    "prisma",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/session": "^11.1.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.2",
    "@prisma/client": "^6.9.0",
    "@scure/bip32": "^1.6.2",
    "@scure/bip39": "^1.5.4",
    "@types/qrcode": "^1.5.6",
    "argon2": "^0.44.0",
    "commander": "^13.1.0",
    "fastify": "^5.3.2",
    "prisma": "^6.9.0",
    "qrcode": "^1.5.4",
    "tronweb": "^5.2.0",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "audit-ci": "^7.1.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.31.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "axios": "^1.12.0",
    "ws": "^8.17.1",
    "elliptic": "^6.6.1",
    "lodash": "^4.17.21"
  }
}
