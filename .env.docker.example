# ──────────────────────────────────────────────────────────────────────────────
# Stablerails Docker Compose — environment example
# Copy to .env for local dev. Fill in real values before going live.
# NEVER commit .env — it is gitignored.
#
# IMPORTANT: docker-compose.yml does NOT load this file wholesale into the
# containers (no `env_file:`). Each service declares an explicit allowlist of
# variables; values below are picked up via compose `${VAR}` interpolation.
# Anything not on the allowlist (notably the signer/operator secrets at the
# bottom) never reaches the watch-only containers.
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════
# SERVER / WORKER VARS (watch-only containers)
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────
# Overridden per-service in docker-compose.yml to use the internal hostname.
# Keep this here as a fallback for local non-Docker runs.
DATABASE_URL="postgresql://stablerails:stablerails_dev@localhost:5432/stablerails"

# ── Tron RPC (worker) ────────────────────────────────────────────────────────
# Configure two distinct same-network endpoints before starting the worker.
# Leave blank to fail fast. Do not mix mainnet with Nile/testnet.
TRON_RPC_PRIMARY_URL=""
TRON_RPC_PRIMARY_API_KEY=""

# Secondary must differ from primary but remain on the same network.
TRON_RPC_SECONDARY_URL=""
TRON_RPC_SECONDARY_API_KEY=""

# USDT contract override (Base58). Empty/unset = mainnet default.
# Nile testnet USDT contract (for testnet dev runs):
# TRON_USDT_CONTRACT="TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf"
TRON_USDT_CONTRACT=""

# ── Server ───────────────────────────────────────────────────────────────────
PORT="3000"
HOST="0.0.0.0"
NODE_ENV="production"
STABLERAILS_ENV="production"
LOG_LEVEL="info"
PUBLIC_BASE_URL="http://localhost:3000"

# ── Webhook-secret encryption at rest ────────────────────────────────────────
# Optional 32-byte data key (64 hex chars). When set, webhook HMAC secrets are
# stored AES-256-GCM-encrypted (a read-only DB compromise cannot forge webhook
# signatures). Unset = plaintext storage (legacy behaviour, warning logged).
# BOTH server (stores secrets at registration) and worker (decrypts for
# delivery signing) need the SAME key.
# Generate with: openssl rand -hex 32
STABLERAILS_DATA_KEY=""

# ── Kill-switches (boot-time only) ───────────────────────────────────────────
STABLERAILS_PAUSE_INVOICES=""
STABLERAILS_PAUSE_WATCHER=""
STABLERAILS_PAUSE_WEBHOOKS=""

# ── Demo page ────────────────────────────────────────────────────────────────
# Set to "1" to enable GET /demo and POST /demo/order.
# Default OFF — opt in explicitly for local dev. Never enable in production.
# Also set STABLERAILS_ENV="development"; docker-compose binds the demo to localhost.
ENABLE_DEMO=""
# Merchant API key used server-side by the demo page (created by dev-bootstrap.sh)
DEMO_MERCHANT_KEY=""
# Event ID used by the demo page (created by dev-bootstrap.sh)
DEMO_EVENT_ID=""

# ═══════════════════════════════════════════════════════════════════════════
# OPERATOR-ONLY / SIGNER VARS — DO NOT put these in server/worker env
# ═══════════════════════════════════════════════════════════════════════════
# These belong on the OPERATOR'S LOCAL MACHINE only (CLI + signer), NOT in the
# deployed compose stack. The watch-only server/worker containers must never
# see the encrypted seed, the main wallet pin, or the admin API key — a server
# compromise must not yield key material (CLAUDE.md "Server↛signer boundary").
# docker-compose.yml deliberately does not pass any of these to its services.

# Admin API key used BY the operator CLI as a client credential (the server
# reads API keys from the database, not from env)
STABLERAILS_ADMIN_KEY=""
# Base URL the operator CLI talks to
STABLERAILS_API_URL="http://localhost:3000"
# Encrypted seed blob for local signing (or use STABLERAILS_SEED_FILE)
STABLERAILS_ENCRYPTED_SEED='{"ciphertext":"","salt":"","iv":"","tag":""}'
# STABLERAILS_SEED_FILE="/path/to/seed.json"
# Sweep destination pin (SIGN-2) — main wallet Base58 address
STABLERAILS_MAIN_WALLET=""
