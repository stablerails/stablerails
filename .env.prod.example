# .env.prod.example — Stablerails production environment variables
#
# Copy this to .env on the server (done automatically by deploy-hetzner.sh deploy).
# DO NOT commit a .env file with real values — this example file has placeholders only.
#
# WATCH-ONLY NOTE: The server and worker never hold signing keys.
# STABLERAILS_ENCRYPTED_SEED, STABLERAILS_MAIN_WALLET, STABLERAILS_ADMIN_KEY, and
# TRON_RPC_PRIMARY (sweep broadcast URL) belong on the OPERATOR'S LOCAL MACHINE,
# NOT on this server. Cash-out (sweep) runs locally via the CLI.

# ── Database ──────────────────────────────────────────────────────────────────
# Internal URL — uses the postgres service name within the compose network.
# The docker-compose.prod.yml assembles this from POSTGRES_USER/PASSWORD/DB,
# but you can set it explicitly here to override.
DATABASE_URL=postgresql://stablerails:CHANGE_ME_STRONG_PASSWORD@postgres:5432/stablerails

# Postgres credentials (used by the postgres service and DATABASE_URL above)
POSTGRES_USER=stablerails
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=stablerails

# ── Tron RPC (mainnet — two distinct endpoints required) ──────────────────────
# Both URLs must point to the SAME network (mainnet). Mixing mainnet + testnet
# will cause the two-RPC agreement check to never confirm payments.
#
# Recommended providers: TronGrid (api.trongrid.io), GetBlock, NOWNodes, Ankr
# Primary and secondary MUST differ — same URL for both defeats the purpose.
TRON_RPC_PRIMARY_URL=https://api.trongrid.io
TRON_RPC_SECONDARY_URL=https://rpc.ankr.com/tron

# API keys for the RPC providers (optional but strongly recommended to avoid rate-limiting)
TRON_RPC_PRIMARY_API_KEY=your-trongrid-api-key-here
TRON_RPC_SECONDARY_API_KEY=your-secondary-provider-api-key-here

# ── Application ───────────────────────────────────────────────────────────────
# Public-facing base URL — used in invoice checkout links
PUBLIC_BASE_URL=https://pay.example.com

# Domain for Caddy TLS (must match your DNS A record)
DOMAIN=pay.example.com

# Admin bearer key for the HTTP API.
# Generated after first bootstrap: POST /v1/api-keys (scope: admin) via browser/curl.
# Leave empty on first deploy; set after running the bootstrap steps in the runbook.
STABLERAILS_ADMIN_KEY=

# ── Optional tuning ───────────────────────────────────────────────────────────

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Grace period (days) during which payments arriving after invoice expiry still credit
LATE_FUNDS_GRACE_DAYS=7

# Watcher + webhook delivery poll intervals (milliseconds)
# WATCHER_POLL_INTERVAL_MS=5000
# WEBHOOK_POLL_INTERVAL_MS=5000

# ── Kill-switch boot-time flags (optional, default: unset = all systems go) ────
# Set to "1" to pause at startup. Runtime control preferred: use the admin API.
# STABLERAILS_PAUSE_INVOICES=
# STABLERAILS_PAUSE_WATCHER=
# STABLERAILS_PAUSE_WEBHOOKS=

# ── Demo mode (LEAVE EMPTY IN PRODUCTION) ────────────────────────────────────
# Demo routes expose unauthenticated checkout pages — never enable on a live instance.
# ENABLE_DEMO=
# DEMO_EVENT_ID=
# DEMO_MERCHANT_KEY=

# ── Metrics ───────────────────────────────────────────────────────────────────
# Prometheus scrape endpoint GET /metrics.
# Empty (default) = endpoint disabled → responds 404 (feature hidden).
# Set to a long random secret to enable; restrict /metrics to scraper IPs via Caddy.
METRICS_TOKEN=

# ── NOT ON THIS SERVER (operator's local machine only) ────────────────────────
# These vars belong on the machine that runs `sweep execute`, NOT the server.
# Including them here as documentation only — do not populate on the server.
#
# STABLERAILS_ENCRYPTED_SEED=   # encrypted seed blob — local machine only
# STABLERAILS_SEED_FILE=         # path to encrypted seed file — local machine only
# STABLERAILS_MAIN_WALLET=       # T... sweep destination address — local machine only
# TRON_RPC_PRIMARY=           # enables live broadcast in sweep execute — local only
# TRON_RPC_SECONDARY=         # fallback broadcast node — local only
# STABLERAILS_MCP_KEY=           # readonly key for MCP server — local only
# STABLERAILS_API_URL=           # server URL for CLI/MCP — local only
